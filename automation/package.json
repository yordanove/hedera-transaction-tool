{
  "name": "hedera-transaction-tool-tests",
  "scripts": {
    "test": "playwright test",
    "test:list": "playwright test --list",
    "postinstall": "node ../notice-gen/index.js",
    "grafana:start": "docker-compose -f k6/docker-compose.yml up -d",
    "grafana:stop": "docker-compose -f k6/docker-compose.yml down",
    "grafana:logs": "docker-compose -f k6/docker-compose.yml logs -f",
    "k6:smoke": "k6 run k6/scripts/smoke-test.js",
    "k6:smoke:grafana": "k6 run --out influxdb=http://localhost:8086/k6 k6/scripts/smoke-test.js",
    "k6:tabs": "k6 run k6/scripts/tab-load-times.js",
    "k6:tabs:grafana": "k6 run --out influxdb=http://localhost:8086/k6 k6/scripts/tab-load-times.js",
    "k6:ready-to-sign": "k6 run k6/scripts/ready-to-sign.js",
    "k6:ready-to-sign:grafana": "k6 run --out influxdb=http://localhost:8086/k6 k6/scripts/ready-to-sign.js",
    "k6:sign-all": "k6 run k6/scripts/sign-all.js",
    "k6:sign-all:grafana": "k6 run --out influxdb=http://localhost:8086/k6 k6/scripts/sign-all.js",
    "k6:seed": "node k6/helpers/seed-test-users.js",
    "k6:perf": "npm run k6:seed && k6 run -e USER_EMAIL=admin@test.com -e USER_PASSWORD=1234567890 k6/scripts/tab-load-times.js"
  },
  "main": "playwright.config.js",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "@hashgraph/proto": "2.19.0",
    "@hashgraph/sdk": "2.66.0",
    "@playwright/test": "1.56.1",
    "argon2": "0.41.1",
    "async-retry": "1.3.3",
    "axios": "1.8.3",
    "bcryptjs": "2.4.3",
    "bip39": "3.1.0",
    "deep-diff": "1.0.2",
    "dotenv": "16.4.7",
    "fsevents": "2.3.2",
    "jszip": "^3.10.1",
    "lodash": "4.17.21",
    "long": "5.2.3",
    "pg": "8.13.1",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "prettier": "3.4.2",
    "sqlite3": "5.1.7",
    "uuid": "10.0.0"
  }
}
