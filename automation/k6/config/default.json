{
  "baseUrl": "http://localhost:3001",
  "endpoints": {
    "auth": {
      "login": "/auth/login",
      "logout": "/auth/logout"
    },
    "transactions": {
      "list": "/transactions",
      "history": "/transactions/history",
      "readyToSign": "/transactions/sign",
      "readyToApprove": "/transactions/approve",
      "single": "/transactions/:id",
      "create": "/transactions",
      "execute": "/transactions/execute/:id"
    },
    "signers": {
      "list": "/transactions/:transactionId/signers",
      "user": "/transactions/:transactionId/signers/user",
      "upload": "/transactions/:transactionId/signers"
    },
    "groups": {
      "list": "/transaction-groups",
      "single": "/transaction-groups/:id"
    },
    "users": {
      "list": "/users",
      "me": "/users/me"
    },
    "notifications": {
      "list": "/notifications",
      "count": "/notifications/count"
    }
  },
  "thresholds": {
    "pageLoadTime": 1000,
    "signAll100Transactions": 4000,
    "apiResponseTime": 500
  }
}
